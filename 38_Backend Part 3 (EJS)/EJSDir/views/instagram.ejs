<%-include("includes/head.ejs");%>


<body>
    <h1>This page is belong to : <%= data.name %>
    </h1>
    <button>Follow</button>
    <button>Massege</button>

    <p>Followers: <%= data.followers%>
    </p>
    <p>Followings: <%= data.following%>
    </p>
    <hr>
    <% for (let post of data.posts) { %>
        <img src="<%= post.image %>" alt="some image">
        <p>Likes: <%= post.likes%>
        </p>
        <p>comments: <%= post.comments%>
        </p>
        <% }%>




</body>

</html>